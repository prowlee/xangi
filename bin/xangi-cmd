#!/bin/bash
# xangi-cmd — xangi tool-server 的 CLI 包装器
#
# 用法:
#   xangi-cmd discord_history --channel 123456 --count 10
#   xangi-cmd discord_send --channel 123456 --message "hello"
#   xangi-cmd schedule_list
#
# 连接地址通过环境变量 XANGI_TOOL_SERVER 显式指定。
# 假设由 xangi 主进程在启动子进程时注入。

# 端口检测
resolve_server() {
  if [ -n "$XANGI_TOOL_SERVER" ]; then
    echo "$XANGI_TOOL_SERVER"
    return
  fi
  return 1
}

TOOL_SERVER=$(resolve_server) || {
  echo "错误: XANGI_TOOL_SERVER 未设置" >&2
  echo "请在 xangi 下启动，或指定 XANGI_TOOL_SERVER=http://127.0.0.1:<port>" >&2
  exit 1
}
COMMAND="$1"
shift

if [ -z "$COMMAND" ] || [ "$COMMAND" = "help" ]; then
  echo "xangi-cmd — xangi 命令 CLI

Discord 操作:
  discord_history   获取频道历史记录
  discord_send      发送消息
  discord_channels  频道列表
  discord_search    搜索消息
  discord_edit      编辑消息
  discord_delete    删除消息
  media_send        发送文件

日程:
  schedule_list     显示列表
  schedule_add      添加
  schedule_remove   删除
  schedule_toggle   启用/禁用切换

系统:
  system_restart    重启
  system_settings   更改设置"
  exit 0
fi

# 将参数从 --key value 对转换为 JSON 对象
FLAGS="{"
FIRST=true
while [ $# -gt 0 ]; do
  case "$1" in
    --*)
      KEY="${1#--}"
      shift
      VALUE="$1"
      shift
      if [ "$FIRST" = true ]; then
        FIRST=false
      else
        FLAGS+=","
      fi
      # JSON 转义（换行、双引号、反斜杠）
      VALUE=$(printf '%s' "$VALUE" | sed 's/\\/\\\\/g; s/"/\\"/g' | awk '{printf "%s\\n", $0}' | sed '$ s/\\n$//')
      FLAGS+="\"$KEY\":\"$VALUE\""
      ;;
    *)
      shift
      ;;
  esac
done
FLAGS+="}"

CONTEXT="{}"
if [ -n "$XANGI_CHANNEL_ID" ]; then
  ESCAPED_CHANNEL_ID=$(printf '%s' "$XANGI_CHANNEL_ID" | sed 's/\\/\\\\/g; s/"/\\"/g')
  CONTEXT="{\"channelId\":\"$ESCAPED_CHANNEL_ID\"}"
fi

# 向 tool-server 发送请求
RESPONSE=$(curl -sf "$TOOL_SERVER/api/execute" \
  -H 'Content-Type: application/json' \
  -d "{\"command\":\"$COMMAND\",\"flags\":$FLAGS,\"context\":$CONTEXT}" 2>&1)

CURL_EXIT=$?

if [ $CURL_EXIT -ne 0 ]; then
  echo "错误: 无法连接到 tool-server ($TOOL_SERVER)" >&2
  echo "请确认 XANGI_TOOL_SERVER 的值以及 xangi 进程的启动状态" >&2
  exit 1
fi

# 从 JSON 响应中提取 result（如果有 jq 则使用，否则直接输出）
if command -v jq &>/dev/null; then
  OK=$(echo "$RESPONSE" | jq -r '.ok // false')
  if [ "$OK" = "true" ]; then
    echo "$RESPONSE" | jq -r '.result'
  else
    echo "$RESPONSE" | jq -r '.error // "未知错误"' >&2
    exit 1
  fi
else
  echo "$RESPONSE"
fi
